# ─────────────────────────────────────────────────────────────
# MATLAB Code Generation Agent — Environment Template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Ollama LLM Settings ───────────────────────────────────────
# URL of your Ollama server (default: local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use. Recommended for 8GB RAM:
#   qwen2.5-coder:1.5b  → ~1.1GB RAM, fastest
#   qwen2.5-coder:3b    → ~2.2GB RAM, best quality/speed tradeoff  ← DEFAULT
#   phi4-mini:3.8b      → ~2.5GB RAM, strong reasoning
#   qwen2.5-coder:7b    → ~4.5GB RAM, highest quality (tight on RAM with MATLAB running)
OLLAMA_MODEL=qwen2.5-coder:3b

# Max tokens the model generates per call (keep ≤ 2048 for 3B models)
LLM_MAX_TOKENS=2048

# Temperature: lower = more deterministic code (0.1–0.2 recommended)
LLM_TEMPERATURE=0.15

# Timeout per LLM API call in seconds
LLM_TIMEOUT_SEC=120.0

# ── MATLAB Settings ───────────────────────────────────────────
# Full path to matlab.exe (auto-detected if not set)
# Example:
# MATLAB_PATH=D:\Matlab\install\bin\matlab.exe
MATLAB_PATH=

# Timeout for each MATLAB subprocess run (seconds)
# Increase to 180+ if MATLAB startup is slow on your machine
MATLAB_EXEC_TIMEOUT_SEC=120.0

# Disable JVM to drastically speed up MATLAB startup (saves 30–60s per run).
# Set to false ONLY if generating GUI-based MATLAB code.
MATLAB_NO_JVM=true

# ── Pipeline Controls ─────────────────────────────────────────
# Max number of Debugger retries before giving up
MAX_DEBUG_RETRIES=3

# Set to true to skip human approval before execution / saving to workspace
AUTO_APPROVE=false

